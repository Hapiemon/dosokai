// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Form {
  id        String   @id @default(cuid())
  formId    String   @unique // "form1", "form2" など
  title     String   // フォームのタイトル
  status    String   @default("実施中") // "実施中" または "終了"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("forms")
}

model Response {
  id                String   @id @default(cuid())
  lastName          String   // 姓
  firstName         String   // 名
  maidenName        String?  // 旧姓
  class             String   // 1, 2, 3, 4, 不明
  eventMay3         Int      // 2026年5月3日参加: 0=参加しない, 1=参加する
  eventSep20        Int      // 2026年9月20日参加: 0=参加しない, 1=参加する
  notAttending      Int      @default(0) // 不参加: 0=不参加ではない, 1=不参加
  companionStatus   String   // 無し, 有り
  companionAdults   Int?     // 同伴者(大人)
  companionChildren Int?     // 同伴者(子供)
  hasAllergy        Boolean
  allergyDetails    String?  // アレルギーの詳細
  remarks           String?  // 備考
  formId            String   @default("form1") // どのフォームへの応答か
  createdAt         DateTime @default(now())

  @@map("responses")
}
